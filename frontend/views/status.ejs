<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Family Dining</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-shell">
  <%- include('partials/navbar', { activeTab: 'status' }) %>
  <% if (flash) { %>
    <div class="container mt-3">
      <div class="alert alert-<%= flash.type %> shadow-sm"><%= flash.text %></div>
    </div>
  <% } %>
  <section class="subpage-hero">
    <div class="container subpage-copy">
      <p class="eyebrow">Status Tracker</p>
      <h1>Check your latest booking by phone number.</h1>
      <p class="subpage-note">Clear, elegant status updates for bookings, waitlist position, and expected wait time.</p>
    </div>
  </section>
  <% if (booking && booking.status === "CONFIRMED") { %>
    <section class="container mt-3">
      <div class="alert alert-success shadow-sm">Booking confirmed! Your table is ready. We look forward to serving you.</div>
    </section>
  <% } %>
  <section class="container pb-5">
    <div class="status-grid-main">
      <div class="status-main-col">
        <form action="/status" method="post" class="reservation-panel compact">
          <div class="panel-header">
            <span class="panel-kicker">Find Booking</span>
            <h2>Track your reservation</h2>
            <p>Use the same phone number shared during booking or waitlist registration.</p>
          </div>
          <label class="form-label">Phone number</label>
          <div class="d-flex gap-2 flex-wrap">
            <input class="form-control luxury-input" type="tel" name="phone" required>
            <button class="btn btn-gold" type="submit">Find booking</button>
          </div>
        </form>
        <% if (booking) { %>
          <article class="support-card mt-4">
            <div class="panel-header mb-2">
              <span class="panel-kicker">Booking Found</span>
              <h2>Latest reservation </h2>
              <p>Open the themed modal for full booking details.</p>
            </div>
            <button class="btn btn-outline-gold" id="openBookingStatusModal" type="button">View booking details</button>
          </article>
        <% } else { %>
          <div class="empty-state">
            <h2>No booking loaded yet</h2>
            <p>Search with the same phone number used during booking or waitlist registration.</p>
          </div>
        <% } %>
      </div>
      
      <div class="status-side-col">
        <aside class="support-card mb-4">
          <div class="panel-header">
            <span class="panel-kicker">Guest Support</span>
            <h2>What this page helps with</h2>
          </div>
          <ul class="support-list">
            <li>Check whether the booking is confirmed or waiting.</li>
            <li>Review table assignment when a table has already been allocated.</li>
            <li>See the latest estimated wait time for queue entries.</li>
            <li>Cancel an active booking if plans change.</li>
          </ul>
        </aside>

        <!-- Dynamic Floor Plan -->
        
      </div>
    </div>
  </section>

  <% if (booking) { %>
    <dialog id="bookingStatusDialog" class="luxury-modal">
      <article class="support-card luxury-modal-card">
        <div class="luxury-modal-actions">
          <button class="btn-close-luxury" id="closeBookingStatusModal" type="button" aria-label="Close">&times;</button>
        </div>
        <p class="eyebrow">Booking #<%= booking.id %></p>
        <h2><%= booking.name %></h2>
        <p class="mb-4">Your latest reservation details are shown below.</p>
        <div class="status-grid">
          <div><span>Status</span><strong><%= booking.status %></strong></div>
          <div><span>Phone</span><strong><%= booking.phone %></strong></div>
          <div><span>Guests</span><strong><%= booking.guests %></strong></div>
          <div><span>Date</span><strong><%= booking.booking_date.toISOString().slice(0, 10) %></strong></div>
          <div><span>Time</span><strong><%= booking.booking_time.toString().slice(0, 5) %></strong></div>
          <div><span>Estimated wait</span><strong><% 
            const wt = booking.wait_time_minutes || 0;
            const hh = Math.floor(wt / 60);
            const mm = wt % 60;
            %><%= hh > 0 ? `${hh}h ${mm}m` : `${mm}m` %></strong></div>
        </div>
        <% if (booking.status !== "CANCELLED" && booking.status !== "COMPLETED") { %>
          <form action="/bookings/<%= booking.id %>/cancel" method="post" class="mt-4">
            <button class="btn btn-outline-gold" type="submit">Cancel booking</button>
          </form>
        <% } %>
      </article>
    </dialog>
  <% } %>

  <script src="/sse-client.ejs"></script>
  <% if (booking) { %>
    <script>
      (function () {
        const bookingStatusDialog = document.getElementById('bookingStatusDialog');
        const closeBookingStatusModal = document.getElementById('closeBookingStatusModal');
        const openBookingStatusModal = document.getElementById('openBookingStatusModal');
        if (!bookingStatusDialog) return;

        if (typeof bookingStatusDialog.showModal === 'function') {
          bookingStatusDialog.showModal();
        } else {
          bookingStatusDialog.setAttribute('open', 'open');
        }

        if (openBookingStatusModal) {
          openBookingStatusModal.addEventListener('click', function () {
            if (!bookingStatusDialog.open) {
              bookingStatusDialog.showModal();
            }
          });
        }

        if (closeBookingStatusModal) {
          closeBookingStatusModal.addEventListener('click', function () {
            bookingStatusDialog.close();
          });
        }

        bookingStatusDialog.addEventListener('click', function (event) {
          if (event.target === bookingStatusDialog) {
            bookingStatusDialog.close();
          }
        });
      })();
    </script>
  <% } %>
  <footer class="luxury-footer">
    <div class="container">
      <div class="footer-copy">A composed guest-facing experience reduces front-desk confusion and repeated status calls.</div>
      <div class="footer-copy">Family Dining House \\ @yogi </div>
    </div>
  </footer>
</body>
</html>




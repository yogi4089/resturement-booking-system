<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Aurevo Dining</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
</head>
<body class="page-shell">
  <%- include('partials/admin-topbar', { activeAdminTab }) %>
  <%- include('partials/admin-toast') %>

  <section class="subpage-hero admin-page-hero">
    <div class="container subpage-copy">
      <p class="eyebrow">Analytics</p>
      <h1>Real-Time Insights</h1>
      <p class="subpage-note">Live demand patterns, turnover metrics, and queue accuracy — updated every page load.</p>
    </div>
  </section>

  <section class="container pb-5">

    <!-- Summary Stats Row -->
    <div class="metrics-grid mb-4">
      <article class="metric-card">
        <span>Confirmed</span>
        <strong><%= summary.confirmed_count %></strong>
      </article>
      <article class="metric-card">
        <span>Waiting</span>
        <strong><%= summary.waiting_count %></strong>
      </article>
      <article class="metric-card">
        <span>Avg Wait</span>
        <strong><%= summary.avg_wait_time %> mins</strong>
      </article>
      <article class="metric-card">
        <span>Current Profile</span>
        <strong><%= summary.current_wait_profile %> (x<%= summary.current_profile_multiplier %>)</strong>
      </article>
      <article class="metric-card">
        <span>Avg Seated Duration</span>
        <strong><%= turnover.avg_seated_duration %> mins</strong>
      </article>
      <article class="metric-card">
        <span>Predicted Wait</span>
        <strong><%= turnover.avg_predicted %> mins</strong>
      </article>
    </div>

    <!-- Charts Row 1: Peak Volume + Bookings by Day -->
    <div class="insights-chart-row mb-4">
      <div class="insights-chart-card">
        <h3 class="insights-chart-title">📊 Peak Booking Hours</h3>
        <p class="insights-chart-sub">Total bookings per hour of day (all time)</p>
        <canvas id="hourChart" height="120"></canvas>
      </div>
      <div class="insights-chart-card">
        <h3 class="insights-chart-title">📅 Bookings by Day of Week</h3>
        <p class="insights-chart-sub">Which days bring the most guests</p>
        <canvas id="dayChart" height="120"></canvas>
      </div>
    </div>

    <!-- Charts Row 2: Wait by Demand Bucket + Turnover Accuracy -->
    <div class="insights-chart-row mb-4">
      <div class="insights-chart-card">
        <h3 class="insights-chart-title">🌙 Avg Wait by Demand Bucket</h3>
        <p class="insights-chart-sub">Which time profiles drive wait times up</p>
        <canvas id="bucketChart" height="180"></canvas>
      </div>
      <div class="insights-chart-card">
        <h3 class="insights-chart-title">⏱ Turnover Accuracy</h3>
        <p class="insights-chart-sub">Predicted vs actual wait vs avg seated duration (mins)</p>
        <canvas id="turnoverChart" height="180"></canvas>
      </div>
    </div>

  </section>

  <footer class="luxury-footer">
    <div class="container">
      <div class="footer-copy">Analytics refresh on each page load. Overdue table alerts fire every 60 seconds via the bell tray.</div>
      <div class="footer-copy">Aurevo Dining House</div>
    </div>
  </footer>

  <script>
    // Inject server data into JS
    const hourData    = <%- hourVolumeJson %>;
    const dayData     = <%- dayVolumeJson %>;
    const bucketData  = <%- bucketWaitJson %>;
    const turnoverData = {
      predicted: <%= turnover.avg_predicted %>,
      actual:    <%= turnover.avg_actual %>,
      seated:    <%= turnover.avg_seated_duration %>
    };

    // Shared chart config
    const BRONZE = 'rgba(165, 110, 50, 0.85)';
    const GOLD = 'rgba(212, 175, 55, 0.85)';
    const GOLD_BORDER = 'rgba(212, 175, 55, 1)';
    const AMBER = 'rgba(255, 150, 20, 0.85)';
    const SLATE = 'rgba(112, 128, 144, 0.75)';
    const SILVER = 'rgba(180, 180, 180, 0.75)';
    const EMERALD = 'rgba(85, 140, 90, 0.75)';

    const chartDefaults = {
      color: '#c8b97a',
      plugins: {
        legend: {
          labels: {
            color: '#c8b97a',
            font: { family: 'Manrope', size: 11 },
            padding: 15
          }
        }
      },
      scales: {
        x: { ticks: { color: '#9a8c5c' }, grid: { color: 'rgba(255,255,255,0.05)' } },
        y: { ticks: { color: '#9a8c5c' }, grid: { color: 'rgba(255,255,255,0.05)' }, beginAtZero: true }
      }
    };

    // 1. Peak Volume — Bar
    new Chart(document.getElementById('hourChart'), {
      type: 'bar',
      data: {
        labels: hourData.map(r => `${r.hour_slot}:00`),
        datasets: [{
          label: 'Bookings',
          data: hourData.map(r => r.total_bookings),
          backgroundColor: hourData.map(r => {
            const h = r.hour_slot;
            if (h >= 19 && h < 23) return GOLD;     // Peak Dinner
            if (h >= 11 && h <= 15) return AMBER;    // Lunch
            if (h >= 17 && h < 19) return BRONZE;   // Early Dinner
            return 'rgba(120,100,80,0.3)';          // Off hours
          }),
          borderColor: GOLD_BORDER,
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: { ...chartDefaults, plugins: { ...chartDefaults.plugins, legend: { display: false } } }
    });

    // 2. Day Volume — Bar
    new Chart(document.getElementById('dayChart'), {
      type: 'bar',
      data: {
        labels: dayData.map(r => r.day_name),
        datasets: [{
          label: 'Bookings',
          data: dayData.map(r => r.total_bookings),
          backgroundColor: [
            SLATE, SLATE, SLATE, SLATE, BRONZE, AMBER, GOLD
          ],
          borderColor: GOLD_BORDER,
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: { ...chartDefaults, plugins: { ...chartDefaults.plugins, legend: { display: false } } }
    });

    // 3. Demand Bucket — Doughnut
    const bucketColors = [GOLD, AMBER, BRONZE, SLATE, SILVER];
    new Chart(document.getElementById('bucketChart'), {
      type: 'doughnut',
      data: {
        labels: bucketData.map(r => `${r.bucket} (avg ${r.avg_wait}m)`),
        datasets: [{
          data: bucketData.map(r => r.total_bookings),
          backgroundColor: bucketColors,
          borderColor: 'rgba(18, 15, 11, 1)',
          borderWidth: 3,
          hoverOffset: 15
        }]
      },
      options: {
        cutout: '65%',
        plugins: {
          legend: {
            position: 'bottom',
            labels: { boxWidth: 12, usePointStyle: true, padding: 20 }
          }
        }
      }
    });

    // 4. Turnover Accuracy — Horizontal Bar
    new Chart(document.getElementById('turnoverChart'), {
      type: 'bar',
      data: {
        labels: ['Predicted Wait', 'Actual Wait', 'Seated Duration'],
        datasets: [{
          label: 'Minutes',
          data: [turnoverData.predicted, turnoverData.actual, turnoverData.seated],
          backgroundColor: [AMBER, GOLD, EMERALD],
          borderColor: GOLD_BORDER,
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        indexAxis: 'y',
        ...chartDefaults,
        plugins: { ...chartDefaults.plugins, legend: { display: false } }
      }
    });
  </script>

  <%- include('partials/sse-client') %>
</body>
</html>

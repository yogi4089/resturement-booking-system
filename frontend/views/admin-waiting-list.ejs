<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Aurevo Dining</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-shell">
  <%- include('partials/admin-topbar', { activeAdminTab }) %>
  <%- include('partials/admin-toast') %>

  <%
    function buildHref(baseQuery, pageKey, pageValue) {
      const entries = Object.entries({ ...baseQuery, [pageKey]: pageValue });
      const query = entries
        .filter(([, value]) => value !== undefined && value !== null && String(value).trim() !== '')
        .map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`)
        .join('&');
      return `/admin/waiting-list${query ? `?${query}` : ''}`;
    }
  %>

  <section class="subpage-hero admin-page-hero">
    <div class="container subpage-copy">
      <p class="eyebrow">Waiting List</p>
      <h1>Control queue decisions and current floor occupancy.</h1>
      <p class="subpage-note">Seat from queue with suggested table preselected, and monitor all occupied tables in one page.</p>
      <p class="subpage-note"><%= recommendedSort %></p>
    </div>
  </section>

  <section class="container pb-5">
    <div class="admin-section-switch" role="tablist" aria-label="Waiting list sections">
      <button type="button" class="admin-switch-btn <%= activeView === 'waiting' ? 'is-active' : '' %>" data-target="waiting" role="tab" aria-selected="<%= activeView === 'waiting' ? 'true' : 'false' %>">Waiting Table</button>
      <button type="button" class="admin-switch-btn <%= activeView === 'ready' ? 'is-active' : '' %>" data-target="ready" role="tab" aria-selected="<%= activeView === 'ready' ? 'true' : 'false' %>">Ready Now</button>
      <button type="button" class="admin-switch-btn <%= activeView === 'booked' ? 'is-active' : '' %>" data-target="booked" role="tab" aria-selected="<%= activeView === 'booked' ? 'true' : 'false' %>">Booked Table</button>
    </div>

    <section class="dashboard-panel mb-4" data-section="waiting" <%= activeView === 'waiting' ? '' : 'hidden' %>>
      <div class="panel-header">
        <span class="panel-kicker">Waiting Table</span>
        <h2>Guests in queue</h2>
        <p>Search, filter, and sort queue records. Showing <%= waitingMeta.startItem %>-<%= waitingMeta.endItem %> of <%= waitingMeta.totalItems %>.</p>
      </div>

      <form class="admin-filter-row" method="get" action="/admin/waiting-list">
        <input type="hidden" name="view" value="waiting">
        <input type="hidden" name="wPage" value="1">
        <input type="hidden" name="bPage" value="<%= bookedMeta.currentPage %>">
        <input type="hidden" name="rPage" value="<%= readyMeta.currentPage %>">
        <input type="hidden" name="bSearch" value="<%= bookedControls.search %>">
        <input type="hidden" name="bSort" value="<%= bookedControls.sort %>">
        <input type="hidden" name="rSearch" value="<%= readyControls.search %>">
        <input type="hidden" name="rPriority" value="<%= readyControls.priority %>">
        <input type="hidden" name="rSort" value="<%= readyControls.sort %>">
        <input class="form-control luxury-input" type="text" name="wSearch" value="<%= waitingControls.search %>" placeholder="Search by id, guest, phone">
        <select class="form-select luxury-input" name="wPriority">
          <option value="ALL" <%= waitingControls.priority === 'ALL' ? 'selected' : '' %>>All priorities</option>
          <option value="VIP" <%= waitingControls.priority === 'VIP' ? 'selected' : '' %>>VIP</option>
          <option value="ELDERLY" <%= waitingControls.priority === 'ELDERLY' ? 'selected' : '' %>>Elderly</option>
          <option value="STANDARD" <%= waitingControls.priority === 'STANDARD' ? 'selected' : '' %>>Standard</option>
        </select>
        <select class="form-select luxury-input" name="wSort">
          <option value="priority_arrival" <%= waitingControls.sort === 'priority_arrival' ? 'selected' : '' %>>Priority then arrival</option>
          <option value="wait_desc" <%= waitingControls.sort === 'wait_desc' ? 'selected' : '' %>>Longest wait remaining</option>
          <option value="schedule_asc" <%= waitingControls.sort === 'schedule_asc' ? 'selected' : '' %>>Schedule time (earliest)</option>
          <option value="guest_asc" <%= waitingControls.sort === 'guest_asc' ? 'selected' : '' %>>Guest name (A-Z)</option>
        </select>
        <button class="btn btn-gold" type="submit">Apply</button>
      </form>

      <div class="table-responsive">
        <table class="table table-dark align-middle admin-data-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Guest</th>
              <th>Schedule</th>
              <th>Status</th>
              <th>Priority</th>
              <th>Wait Remaining</th>
              <th>Waiting Till</th>
              <th class="admin-col-action">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!waitingRows.length) { %>
              <tr>
                <td colspan="8" class="text-center py-4">No queue records found for current filters.</td>
              </tr>
            <% } %>
            <% waitingRows.forEach((row) => { %>
              <tr>
                <td><%= row.booking_id %></td>
                <td class="admin-col-guest"><strong><%= row.name %></strong><small><%= row.phone %> &middot; <%= row.guests %> guests</small></td>
                <td><%= row.scheduleLabel %></td>
                <td><span class="badge text-bg-secondary"><%= row.status %></span></td>
                <td><span class="badge text-bg-dark"><%= row.priority_label %></span></td>
                <td class="dynamic-wait" data-time="<%= row.waitingTill ? row.waitingTill.toISOString() : '' %>"><%= row.waitRemainingLabel %></td>
                <td><%= row.waitingTillLabel %></td>
                <td class="admin-col-action">
                  <% if (row.candidateTables.length) { %>
                    <form action="/admin/queue/<%= row.booking_id %>/promote" method="post" class="admin-seat-form">
                      <input type="hidden" name="returnTo" value="<%= waitingReturnTo %>">
                      <select name="table_id" class="form-select form-select-sm luxury-input">
                        <% row.candidateTables.forEach((table) => { %>
                          <option value="<%= table.id %>" <%= Number(row.suggestedTableId) === Number(table.id) ? 'selected' : '' %>>
                            Table <%= table.id %> � <%= table.capacity %> seats
                          </option>
                        <% }) %>
                      </select>
                      <button class="btn btn-gold btn-sm mt-2 w-100" type="submit">Give Seat</button>
                    </form>
                  <% } else { %>
                    <div class="admin-no-table-actions">
                      <button class="btn btn-outline-light btn-sm w-100 mb-2" type="button" disabled>All Tables Occupied</button>
                      <div class="d-flex gap-2">
                        <form action="/admin/queue/<%= row.booking_id %>/wait/add" method="post">
                          <input type="hidden" name="returnTo" value="<%= waitingReturnTo %>">
                          <input type="hidden" name="minutes" value="10">
                          <button class="btn btn-outline-light btn-sm" type="submit">+10m</button>
                        </form>
                        <form action="/admin/queue/<%= row.booking_id %>/wait/add" method="post">
                          <input type="hidden" name="returnTo" value="<%= waitingReturnTo %>">
                          <input type="hidden" name="minutes" value="15">
                          <button class="btn btn-outline-light btn-sm" type="submit">+15m</button>
                        </form>
                      </div>
                    </div>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="admin-pagination-wrap">
        <span>Page <%= waitingMeta.currentPage %> of <%= waitingMeta.totalPages %></span>
        <div class="admin-pagination-links">
          <% if (waitingMeta.hasPrev) { %>
            <a class="btn btn-outline-light btn-sm" href="<%= buildHref(waitingControls.baseQuery, 'wPage', waitingMeta.prevPage) %>">Previous</a>
          <% } %>
          <% waitingMeta.pageNumbers.forEach((pageNumber) => { %>
            <a class="btn btn-sm <%= pageNumber === waitingMeta.currentPage ? 'btn-gold' : 'btn-outline-light' %>" href="<%= buildHref(waitingControls.baseQuery, 'wPage', pageNumber) %>"><%= pageNumber %></a>
          <% }) %>
          <% if (waitingMeta.hasNext) { %>
            <a class="btn btn-outline-light btn-sm" href="<%= buildHref(waitingControls.baseQuery, 'wPage', waitingMeta.nextPage) %>">Next</a>
          <% } %>
        </div>
      </div>
    </section>

    <section class="dashboard-panel mb-4" data-section="ready" <%= activeView === 'ready' ? '' : 'hidden' %>>
      <div class="panel-header">
        <span class="panel-kicker">Ready Now</span>
        <h2>Wait time reached zero</h2>
        <p>Guests in this list are due now. Assign seats quickly. Showing <%= readyMeta.startItem %>-<%= readyMeta.endItem %> of <%= readyMeta.totalItems %>.</p>
      </div>

      <form class="admin-filter-row" method="get" action="/admin/waiting-list">
        <input type="hidden" name="view" value="ready">
        <input type="hidden" name="rPage" value="1">
        <input type="hidden" name="wPage" value="<%= waitingMeta.currentPage %>">
        <input type="hidden" name="bPage" value="<%= bookedMeta.currentPage %>">
        <input type="hidden" name="wSearch" value="<%= waitingControls.search %>">
        <input type="hidden" name="wPriority" value="<%= waitingControls.priority %>">
        <input type="hidden" name="wSort" value="<%= waitingControls.sort %>">
        <input type="hidden" name="bSearch" value="<%= bookedControls.search %>">
        <input type="hidden" name="bSort" value="<%= bookedControls.sort %>">
        <input class="form-control luxury-input" type="text" name="rSearch" value="<%= readyControls.search %>" placeholder="Search ready guests">
        <select class="form-select luxury-input" name="rPriority">
          <option value="ALL" <%= readyControls.priority === 'ALL' ? 'selected' : '' %>>All priorities</option>
          <option value="VIP" <%= readyControls.priority === 'VIP' ? 'selected' : '' %>>VIP</option>
          <option value="ELDERLY" <%= readyControls.priority === 'ELDERLY' ? 'selected' : '' %>>Elderly</option>
          <option value="STANDARD" <%= readyControls.priority === 'STANDARD' ? 'selected' : '' %>>Standard</option>
        </select>
        <select class="form-select luxury-input" name="rSort">
          <option value="excess_time_desc" <%= readyControls.sort === 'excess_time_desc' ? 'selected' : '' %>>Wait exceeded (longest first)</option>
          <option value="priority_arrival" <%= readyControls.sort === 'priority_arrival' ? 'selected' : '' %>>Priority then arrival</option>
          <option value="schedule_asc" <%= readyControls.sort === 'schedule_asc' ? 'selected' : '' %>>Schedule time (earliest)</option>
          <option value="guest_asc" <%= readyControls.sort === 'guest_asc' ? 'selected' : '' %>>Guest name (A-Z)</option>
        </select>
        <button class="btn btn-gold" type="submit">Apply</button>
      </form>

      <div class="table-responsive">
        <table class="table table-dark align-middle admin-data-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Guest</th>
              <th>Priority</th>
              <th>Schedule</th>
              <th>Wait Remaining</th>
              <th class="admin-col-action">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!readyRows.length) { %>
              <tr>
                <td colspan="6" class="text-center py-4">No guests have zero waiting time right now.</td>
              </tr>
            <% } %>
            <% readyRows.forEach((row) => { %>
              <tr>
                <td><%= row.booking_id %></td>
                <td class="admin-col-guest"><strong><%= row.name %></strong><small><%= row.phone %> &middot; <%= row.guests %> guests</small></td>
                <td><span class="badge text-bg-dark"><%= row.priority_label %></span></td>
                <td><%= row.scheduleLabel %></td>
                <td class="ready-wait-remaining" data-waiting-till="<%= row.waitingTill.toISOString() %>"><%= row.waitRemainingLabel %></td>
                <td class="admin-col-action">
                  <% if (row.candidateTables.length) { %>
                    <form action="/admin/queue/<%= row.booking_id %>/promote" method="post" class="admin-seat-form">
                      <input type="hidden" name="returnTo" value="<%= readyReturnTo %>">
                      <select name="table_id" class="form-select form-select-sm luxury-input">
                        <% row.candidateTables.forEach((table) => { %>
                          <option value="<%= table.id %>" <%= Number(row.suggestedTableId) === Number(table.id) ? 'selected' : '' %>>
                            Table <%= table.id %> � <%= table.capacity %> seats
                          </option>
                        <% }) %>
                      </select>
                      <button class="btn btn-gold btn-sm mt-2 w-100" type="submit">Give Seat</button>
                    </form>
                  <% } else { %>
                    <div class="admin-no-table-actions">
                      <button class="btn btn-outline-light btn-sm w-100 mb-2" type="button" disabled>All Tables Occupied</button>
                      <div class="d-flex gap-2">
                        <form action="/admin/queue/<%= row.booking_id %>/wait/add" method="post">
                          <input type="hidden" name="returnTo" value="<%= readyReturnTo %>">
                          <input type="hidden" name="minutes" value="10">
                          <button class="btn btn-outline-light btn-sm" type="submit">+10m</button>
                        </form>
                        <form action="/admin/queue/<%= row.booking_id %>/wait/add" method="post">
                          <input type="hidden" name="returnTo" value="<%= readyReturnTo %>">
                          <input type="hidden" name="minutes" value="15">
                          <button class="btn btn-outline-light btn-sm" type="submit">+15m</button>
                        </form>
                      </div>
                    </div>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="admin-pagination-wrap">
        <span>Page <%= readyMeta.currentPage %> of <%= readyMeta.totalPages %></span>
        <div class="admin-pagination-links">
          <% if (readyMeta.hasPrev) { %>
            <a class="btn btn-outline-light btn-sm" href="<%= buildHref(readyControls.baseQuery, 'rPage', readyMeta.prevPage) %>">Previous</a>
          <% } %>
          <% readyMeta.pageNumbers.forEach((pageNumber) => { %>
            <a class="btn btn-sm <%= pageNumber === readyMeta.currentPage ? 'btn-gold' : 'btn-outline-light' %>" href="<%= buildHref(readyControls.baseQuery, 'rPage', pageNumber) %>"><%= pageNumber %></a>
          <% }) %>
          <% if (readyMeta.hasNext) { %>
            <a class="btn btn-outline-light btn-sm" href="<%= buildHref(readyControls.baseQuery, 'rPage', readyMeta.nextPage) %>">Next</a>
          <% } %>
        </div>
      </div>
    </section>

    <section class="dashboard-panel" data-section="booked" <%= activeView === 'booked' ? '' : 'hidden' %>>
      <div class="panel-header">
        <span class="panel-kicker">Booked Table</span>
        <h2>Current seated guests</h2>
        <p>Search and sort occupancy records. Showing <%= bookedMeta.startItem %>-<%= bookedMeta.endItem %> of <%= bookedMeta.totalItems %>.</p>
      </div>

      <form class="admin-filter-row" method="get" action="/admin/waiting-list">
        <input type="hidden" name="view" value="booked">
        <input type="hidden" name="bPage" value="1">
        <input type="hidden" name="wPage" value="<%= waitingMeta.currentPage %>">
        <input type="hidden" name="rPage" value="<%= readyMeta.currentPage %>">
        <input type="hidden" name="wSearch" value="<%= waitingControls.search %>">
        <input type="hidden" name="wPriority" value="<%= waitingControls.priority %>">
        <input type="hidden" name="wSort" value="<%= waitingControls.sort %>">
        <input type="hidden" name="rSearch" value="<%= readyControls.search %>">
        <input type="hidden" name="rPriority" value="<%= readyControls.priority %>">
        <input type="hidden" name="rSort" value="<%= readyControls.sort %>">
        <input class="form-control luxury-input" type="text" name="bSearch" value="<%= bookedControls.search %>" placeholder="Search by table, guest, phone">
        <select class="form-select luxury-input" name="bSort">
          <option value="free_soon" <%= bookedControls.sort === 'free_soon' ? 'selected' : '' %>>Free soonest first</option>
          <option value="table_asc" <%= bookedControls.sort === 'table_asc' ? 'selected' : '' %>>Table number (asc)</option>
          <option value="seated_newest" <%= bookedControls.sort === 'seated_newest' ? 'selected' : '' %>>Recently seated first</option>
        </select>
        <button class="btn btn-gold" type="submit">Apply</button>
      </form>

      <div class="table-responsive">
        <table class="table table-dark align-middle admin-data-table">
          <thead>
            <tr>
              <th>Table</th>
              <th>Guest</th>
              <th>Seated At</th>
              <th>Expected Free</th>
              <th>Remaining</th>
              <th class="admin-col-action">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!occupiedRows.length) { %>
              <tr>
                <td colspan="6" class="text-center py-4">No active seated bookings found for current filters.</td>
              </tr>
            <% } %>
            <% occupiedRows.forEach((row) => { %>
              <tr>
                <td class="admin-col-guest"><strong>Table <%= row.tableNumber %></strong><small><%= row.tableCapacity %> seats</small></td>
                <td class="admin-col-guest"><strong><%= row.booking.name %></strong><small><%= row.booking.phone %> &middot; <%= row.booking.guests %> guests</small></td>
                <td><%= row.seatedAtLabel %></td>
                <td><%= row.expectedFreeAtLabel %></td>
                <td class="dynamic-wait" data-time="<%= row.expectedFreeAt ? row.expectedFreeAt.toISOString() : '' %>"><%= row.remainingLabel %></td>
                <td>
                  <div class="d-flex gap-2 flex-wrap admin-booked-actions">
                    <form action="/admin/bookings/<%= row.booking.id %>/extend" method="post">
                      <input type="hidden" name="returnTo" value="<%= bookedReturnTo %>">
                      <button class="btn btn-outline-light btn-sm" type="submit">Extend +15m</button>
                    </form>
                    <form action="/admin/bookings/<%= row.booking.id %>/complete" method="post">
                      <input type="hidden" name="returnTo" value="<%= bookedReturnTo %>">
                      <button class="btn btn-outline-light btn-sm" type="submit">Complete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="admin-pagination-wrap">
        <span>Page <%= bookedMeta.currentPage %> of <%= bookedMeta.totalPages %></span>
        <div class="admin-pagination-links">
          <% if (bookedMeta.hasPrev) { %>
            <a class="btn btn-outline-light btn-sm" href="<%= buildHref(bookedControls.baseQuery, 'bPage', bookedMeta.prevPage) %>">Previous</a>
          <% } %>
          <% bookedMeta.pageNumbers.forEach((pageNumber) => { %>
            <a class="btn btn-sm <%= pageNumber === bookedMeta.currentPage ? 'btn-gold' : 'btn-outline-light' %>" href="<%= buildHref(bookedControls.baseQuery, 'bPage', pageNumber) %>"><%= pageNumber %></a>
          <% }) %>
          <% if (bookedMeta.hasNext) { %>
            <a class="btn btn-outline-light btn-sm" href="<%= buildHref(bookedControls.baseQuery, 'bPage', bookedMeta.nextPage) %>">Next</a>
          <% } %>
        </div>
      </div>
    </section>
  </section>

  <footer class="luxury-footer">
    <div class="container">
      <div class="footer-copy">Queue and floor context together helps hosts seat faster with fewer mistakes.</div>
      <div class="footer-copy">Aurevo Dining House</div>
    </div>
  </footer>

  <script>
    (function () {
      const switchButtons = Array.from(document.querySelectorAll('.admin-switch-btn'));
      const sections = Array.from(document.querySelectorAll('[data-section]'));
      const initialView = '<%= activeView %>';

      function activate(target) {
        switchButtons.forEach((btn) => {
          const isActive = btn.dataset.target === target;
          btn.classList.toggle('is-active', isActive);
          btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });

        sections.forEach((section) => {
          section.hidden = section.dataset.section !== target;
        });
      }

      switchButtons.forEach((btn) => {
        btn.addEventListener('click', function () {
          activate(btn.dataset.target);
        });
      });

      if (initialView === 'booked' || initialView === 'ready') {
        activate(initialView);
      } else {
        activate('waiting');
      }

      function formatMins(mins) {
        if (mins >= 60) {
          const h = Math.floor(mins / 60);
          const m = mins % 60;
          return m ? h + 'h ' + m + 'm' : h + 'h';
        }
        return mins + 'm';
      }

      function updateReadyWaitTimes() {
        const now = new Date();
        document.querySelectorAll('.ready-wait-remaining, .dynamic-wait').forEach(td => {
          const timeAttr = td.dataset.waitingTill || td.dataset.time;
          if (!timeAttr) return;
          const targetTime = new Date(timeAttr);
          const diffMs = now - targetTime;
          if (diffMs > 0) {
            const mins = Math.floor(diffMs / 60000);
            td.textContent = '0m (+' + formatMins(mins) + ')';
          } else {
            const remains = Math.ceil(-diffMs / 60000);
            td.textContent = formatMins(remains);
          }
        });
      }
      setInterval(updateReadyWaitTimes, 60000);
      updateReadyWaitTimes();
    })();
  </script>
  <%- include('partials/sse-client') %>
</body>
</html>





<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Aurevo Dining</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-shell">
  <%- include('partials/navbar', { activeTab: 'booking' }) %>
  <% if (flash) { %>
    <div class="container mt-3">
      <div class="alert alert-<%= flash.type %> shadow-sm"><%= flash.text %></div>
    </div>
  <% } %>
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Dark Luxury Reservation Suite</p>
        <h1>Reserve the evening before the room fills.</h1>
        <p class="lead">Manage premium table bookings, smart waitlisting, and live table readiness in one smooth flow.</p>
        <p class="hero-note">Built for hosts who need confidence at the door and guests who want immediate clarity on their evening.</p>
        <div class="hero-stats">
          <div><span>Current wait</span><strong><%= waitEstimate.waitTime %> mins</strong></div>
          <div><span>Suggested next slot</span><strong><%= waitEstimate.nextSlot.toLocaleTimeString("en-IN", { hour: "numeric", minute: "2-digit" }) %></strong></div>
          <div><span>Current profile</span><strong><%= waitEstimate.waitProfile %></strong></div>
        </div>
      </div>
      <div class="reservation-panel">
        <div class="panel-header">
          <span class="panel-kicker">Book a Table</span>
          <h2>Request a curated seating slot</h2>
          <p>Fast guest capture with immediate confirmation or premium queue placement.</p>
        </div>
        <form action="/bookings" method="post" class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Full name</label>
            <input class="form-control luxury-input" type="text" name="name" value="<%= slotOffer ? slotOffer.formData.name : '' %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Phone</label>
            <input class="form-control luxury-input" type="tel" name="phone" value="<%= slotOffer ? slotOffer.formData.phone : '' %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Date</label>
            <div class="luxury-date-wrap">
              <input id="bookingDateDisplay" class="form-control luxury-input luxury-date-trigger" type="text" readonly placeholder="Select booking date" autocomplete="off" required>
              <input id="bookingDateValue" type="hidden" name="booking_date" value="<%= slotOffer ? slotOffer.formData.booking_date : defaultBookingDate %>" required>
              <div id="bookingDatePicker" class="luxury-datepicker" hidden>
                <div class="luxury-datepicker-header">
                  <h3 id="bookingDatePickerTitle" class="luxury-datepicker-title"></h3>
                  <div class="luxury-datepicker-nav">
                    <button id="bookingDatePrevMonth" type="button" aria-label="Previous month">&#8592;</button>
                    <button id="bookingDateNextMonth" type="button" aria-label="Next month">&#8594;</button>
                  </div>
                </div>
                <div class="luxury-datepicker-weekdays">
                  <span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span><span>Su</span>
                </div>
                <div id="bookingDatePickerDays" class="luxury-datepicker-days"></div>
                <div class="luxury-datepicker-footer">
                  <button id="bookingDateClear" type="button">Clear</button>
                  <button id="bookingDateToday" type="button">Today</button>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Time</label>
            <input class="form-control luxury-input" type="time" name="booking_time" value="<%= slotOffer ? slotOffer.formData.booking_time : defaultBookingTime %>" placeholder="HH:MM" required>
            <small class="text-light-emphasis">Use time like HH:MM (example: 07:30)</small>
          </div>
          <div class="col-md-6">
            <label class="form-label">Guests</label>
            <input class="form-control luxury-input" type="number" min="1" max="12" name="guests" value="<%= slotOffer ? slotOffer.formData.guests : '' %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Priority</label>
            <select class="form-select luxury-input" name="priority">
              <option value="STANDARD" <%= slotOffer && slotOffer.formData.priority === 'STANDARD' ? 'selected' : '' %>>Standard</option>
              <option value="ELDERLY" <%= slotOffer && slotOffer.formData.priority === 'ELDERLY' ? 'selected' : '' %>>Elderly</option>
              <option value="VIP" <%= slotOffer && slotOffer.formData.priority === 'VIP' ? 'selected' : '' %>>VIP</option>
            </select>
          </div>
          <div class="col-12">
            <button class="btn btn-gold w-100" type="submit">Check availability</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <% if (slotOffer) { %>
    <dialog id="slotOfferDialog" class="luxury-modal">
      <article class="support-card luxury-modal-card">
        <div class="luxury-modal-actions">
          <button class="btn btn-outline-light btn-sm" id="closeSlotOfferDialog" type="button">Close</button>
        </div>
        <div class="panel-header">
          <span class="panel-kicker">Alternative Slots</span>
          <h2>No matching table right now</h2>
          <p>Estimated wait: <strong>~<%= slotOffer.waitEstimate.waitTime %> mins</strong> (range <%= slotOffer.waitEstimate.waitRange.min %>-<%= slotOffer.waitEstimate.waitRange.max %> mins, <%= slotOffer.waitEstimate.waitProfile %>, x<%= slotOffer.waitEstimate.multiplier %>).</p>
          <p>Customers ahead for your party size: <strong><%= slotOffer.waitEstimate.components.queueAhead %></strong>. Earliest eligible slot: <strong><%= slotOffer.waitEstimate.earliestEligibleSlot.toLocaleTimeString("en-IN", { hour: "numeric", minute: "2-digit" }) %></strong>.</p>
        </div>
        <div class="alt-slot-grid">
          <% slotOffer.alternatives.forEach((slot) => { %>
            <form action="/bookings/alternative" method="post" class="alt-slot-card">
              <input type="hidden" name="name" value="<%= slotOffer.formData.name %>">
              <input type="hidden" name="phone" value="<%= slotOffer.formData.phone %>">
              <input type="hidden" name="guests" value="<%= slotOffer.formData.guests %>">
              <input type="hidden" name="priority" value="<%= slotOffer.formData.priority %>">
              <input type="hidden" name="booking_date" value="<%= slot.bookingDate %>">
              <input type="hidden" name="booking_time" value="<%= slot.bookingTime %>">
              <h3><%= slot.weekdayShort %>, <%= slot.formattedTime %></h3>
              <p><%= slot.formattedDate %> (<%= slot.weekday %>) at <%= slot.formattedTime %></p>
              <button class="btn btn-gold w-100" type="submit">Book this slot</button>
            </form>
          <% }) %>
        </div>
        <div class="mt-4">
          <h3 class="h5 mb-3">Want to edit your time?</h3>
          <form action="/bookings" method="post" class="row g-2 align-items-end">
            <input type="hidden" name="name" value="<%= slotOffer.formData.name %>">
            <input type="hidden" name="phone" value="<%= slotOffer.formData.phone %>">
            <input type="hidden" name="guests" value="<%= slotOffer.formData.guests %>">
            <input type="hidden" name="priority" value="<%= slotOffer.formData.priority %>">
            <div class="col-md-4">
              <label class="form-label">Date</label>
              <input class="form-control luxury-input" type="date" name="booking_date" value="<%= slotOffer.formData.booking_date %>" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Time</label>
              <input class="form-control luxury-input" type="time" name="booking_time" value="<%= slotOffer.formData.booking_time %>" placeholder="HH:MM" required>
            </div>
            <div class="col-md-4">
              <button class="btn btn-outline-light w-100" type="submit">Update time & check again</button>
            </div>
          </form>
        </div>
        <form action="/bookings/waitlist" method="post" class="mt-3 d-flex flex-wrap gap-2">
          <input type="hidden" name="name" value="<%= slotOffer.formData.name %>">
          <input type="hidden" name="phone" value="<%= slotOffer.formData.phone %>">
          <input type="hidden" name="guests" value="<%= slotOffer.formData.guests %>">
          <input type="hidden" name="priority" value="<%= slotOffer.formData.priority %>">
          <input type="hidden" name="booking_date" value="<%= slotOffer.formData.booking_date %>">
          <input type="hidden" name="booking_time" value="<%= slotOffer.formData.booking_time %>">
          <button class="btn btn-outline-light" type="submit">Join waiting list instead</button>
        </form>
      </article>
    </dialog>
  <% } %>

  <% if (typeof bookingRestricted !== 'undefined' && bookingRestricted) { %>
    <dialog id="restrictionModal" class="luxury-modal">
      <article class="support-card luxury-modal-card">
        <div class="luxury-modal-actions">
          <button class="btn btn-outline-light btn-sm" id="closeRestrictionModal" type="button">Close</button>
        </div>
        <div class="panel-header text-center">
          <span class="panel-kicker">System Closed</span>
          <h2>Bookings Paused</h2>
          <p class="mt-3"><%= restrictedMessage %></p>
        </div>
        <div class="mt-4 text-center">
          <p class="text-muted small">Our digital doors reopen at 08:00 AM. We look forward to seeing you then.</p>
          <a href="/" class="btn btn-gold mt-3">Back to Home</a>
        </div>
      </article>
    </dialog>
  <% } %>

  <section class="info-band">
    <div class="container info-grid">
      <article><h3>Smart availability</h3><p>Tables are matched by capacity first, then confirmed instantly when a suitable table is free.</p></article>
      <article><h3>Priority queue</h3><p>VIP and elderly guests move ahead based on priority score and arrival time, not simple FIFO order.</p></article>
      <article><h3>Demand-aware wait logic</h3><p>Weekday day is lighter, weekday night is higher, Saturday night is heavier, and Sunday night is busiest.</p></article>
    </div>
  </section>

  <section class="container py-5">
    <div class="section-head">
      <div>
        <p class="eyebrow">Tables</p>
        <h2>Room readiness at a glance</h2>
      </div>
      <p class="subpage-note">Manual table control keeps the floor plan realistic during busy service.</p>
    </div>
    <div class="table-grid">
      <% tables.forEach((table) => { %>
        <div class="table-tile <%= table.status === 'AVAILABLE' ? 'is-ready' : 'is-busy' %>">
          <span>Table <%= table.id %></span>
          <strong><%= table.capacity %> seats</strong>
          <em><%= table.status %></em>
          <% if (table.status === 'OCCUPIED') { %>
            <small>Approx <%= Math.floor(table.timeLeftMinutes / 60) > 0 ? `${Math.floor(table.timeLeftMinutes / 60)}h ${table.timeLeftMinutes % 60}m` : `${table.timeLeftMinutes}m` %> until free</small>
            <span class="badge rounded-pill text-bg-warning">Queue <%= queueCount %></span>
          <% } %>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="container pb-5">
    <div class="section-head">
      <div>
        <p class="eyebrow">Quick Dishes</p>
        <h2>Recommended during longer waits</h2>
      </div>
      <p class="subpage-note">Use the public menu to keep waiting guests engaged with quick-turn options.</p>
    </div>
    <div class="menu-preview">
      <% menuItems.slice(0, 3).forEach((item) => { %>
        <article class="menu-card">
          <h3><%= item.name %></h3>
          <p>Prepared quickly to keep guests comfortable while their table opens.</p>
          <strong>Rs. <%= Number(item.price).toFixed(0) %></strong>
        </article>
      <% }) %>
    </div>
  </section>

  <footer class="luxury-footer">
    <div class="container">
      <div class="footer-copy">Priority queueing, clear status tracking, and a premium front-desk flow for modern restaurants.</div>
      <div class="footer-copy">Aurevo Dining House</div>
    </div>
  </footer>
  <script>
    (function () {
      const dateValueInput = document.getElementById('bookingDateValue');
      const dateDisplayInput = document.getElementById('bookingDateDisplay');
      const datepicker = document.getElementById('bookingDatePicker');
      const datepickerTitle = document.getElementById('bookingDatePickerTitle');
      const datepickerDays = document.getElementById('bookingDatePickerDays');
      const prevMonthButton = document.getElementById('bookingDatePrevMonth');
      const nextMonthButton = document.getElementById('bookingDateNextMonth');
      const clearButton = document.getElementById('bookingDateClear');
      const todayButton = document.getElementById('bookingDateToday');
      const dateWrap = dateDisplayInput ? dateDisplayInput.closest('.luxury-date-wrap') : null;

      if (!dateValueInput || !dateDisplayInput || !datepicker || !datepickerTitle || !datepickerDays || !prevMonthButton || !nextMonthButton || !clearButton || !todayButton || !dateWrap) {
        return;
      }

      function startOfDay(date) {
        return new Date(date.getFullYear(), date.getMonth(), date.getDate());
      }

      function parseISO(value) {
        if (!value) return null;
        const parts = value.split('-').map(Number);
        if (parts.length !== 3 || parts.some(Number.isNaN)) return null;
        return new Date(parts[0], parts[1] - 1, parts[2]);
      }

      function toISO(date) {
        const y = date.getFullYear();
        const m = String(date.getMonth() + 1).padStart(2, '0');
        const d = String(date.getDate()).padStart(2, '0');
        return `${y}-${m}-${d}`;
      }

      function isSameDay(a, b) {
        return a && b && a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate();
      }

      function formatDateDisplay(value) {
        const date = parseISO(value);
        if (!date || Number.isNaN(date.getTime())) return '';
        const dd = String(date.getDate()).padStart(2, '0');
        const mm = String(date.getMonth() + 1).padStart(2, '0');
        const yyyy = date.getFullYear();
        const day = date.toLocaleDateString('en-IN', { weekday: 'long' });
        return `${dd}-${mm}-${yyyy} (${day})`;
      }

      function refreshDisplay() {
        dateDisplayInput.value = formatDateDisplay(dateValueInput.value);
      }

      let selectedDate = parseISO(dateValueInput.value);
      let viewDate = selectedDate ? new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1) : new Date(new Date().getFullYear(), new Date().getMonth(), 1);

      function renderCalendar() {
        datepickerTitle.textContent = viewDate.toLocaleDateString('en-IN', { month: 'long', year: 'numeric' });

        const year = viewDate.getFullYear();
        const month = viewDate.getMonth();
        const firstDay = new Date(year, month, 1);
        const offset = (firstDay.getDay() + 6) % 7;
        const gridStart = new Date(year, month, 1 - offset);
        const today = startOfDay(new Date());

        datepickerDays.innerHTML = '';

        for (let i = 0; i < 42; i += 1) {
          const cellDate = new Date(gridStart.getFullYear(), gridStart.getMonth(), gridStart.getDate() + i);
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'luxury-datepicker-day';
          button.textContent = String(cellDate.getDate());
          button.dataset.date = toISO(cellDate);

          if (cellDate.getMonth() !== month) {
            button.classList.add('is-other-month');
          }

          if (isSameDay(cellDate, today)) {
            button.classList.add('is-today');
          }

          if (selectedDate && isSameDay(cellDate, selectedDate)) {
            button.classList.add('is-selected');
          }

          datepickerDays.appendChild(button);
        }
      }

      function closePicker() {
        datepicker.hidden = true;
      }

      function openPicker() {
        datepicker.hidden = false;
        renderCalendar();
      }

      function togglePicker() {
        if (datepicker.hidden) {
          openPicker();
        } else {
          closePicker();
        }
      }

      function selectDateByISO(value) {
        selectedDate = parseISO(value);
        dateValueInput.value = value;
        refreshDisplay();
      }

      dateDisplayInput.addEventListener('click', function () {
        togglePicker();
      });

      dateDisplayInput.addEventListener('keydown', function (event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          togglePicker();
        }
      });

      prevMonthButton.addEventListener('click', function () {
        viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() - 1, 1);
        renderCalendar();
      });

      nextMonthButton.addEventListener('click', function () {
        viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() + 1, 1);
        renderCalendar();
      });

      datepickerDays.addEventListener('click', function (event) {
        const button = event.target.closest('button[data-date]');
        if (!button) return;

        selectDateByISO(button.dataset.date);
        viewDate = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
        closePicker();
      });

      clearButton.addEventListener('click', function () {
        selectedDate = null;
        dateValueInput.value = '';
        dateDisplayInput.value = '';
        renderCalendar();
      });

      todayButton.addEventListener('click', function () {
        const today = startOfDay(new Date());
        selectDateByISO(toISO(today));
        viewDate = new Date(today.getFullYear(), today.getMonth(), 1);
        renderCalendar();
        closePicker();
      });

      document.addEventListener('mousedown', function (event) {
        if (!dateWrap.contains(event.target)) {
          closePicker();
        }
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          closePicker();
        }
      });

      refreshDisplay();
      renderCalendar();

      <% if (slotOffer) { %>
      (function() {
        const slotOfferDialog = document.getElementById('slotOfferDialog');
        const closeSlotOfferDialog = document.getElementById('closeSlotOfferDialog');
        if (slotOfferDialog) {
          if (typeof slotOfferDialog.showModal === 'function') {
            slotOfferDialog.showModal();
          } else {
            slotOfferDialog.setAttribute('open', 'open');
          }

          if (closeSlotOfferDialog) {
            closeSlotOfferDialog.addEventListener('click', function () {
              slotOfferDialog.close();
            });
          }

          slotOfferDialog.addEventListener('click', function (event) {
            if (event.target === slotOfferDialog) {
              slotOfferDialog.close();
            }
          });
        }
      })();
      <% } %>

      <% if (typeof bookingRestricted !== 'undefined' && bookingRestricted) { %>
      (function() {
        const restrictionModal = document.getElementById('restrictionModal');
        const closeRestrictionModal = document.getElementById('closeRestrictionModal');
        if (restrictionModal) {
          if (typeof restrictionModal.showModal === 'function') {
            restrictionModal.showModal();
          } else {
            restrictionModal.setAttribute('open', 'open');
          }

          if (closeRestrictionModal) {
            closeRestrictionModal.addEventListener('click', function () {
              restrictionModal.close();
            });
          }
        }
      })();
      <% } %>
    })();
  </script>
</body>
</html>
















<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Aurevo Dining</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-shell">
  <%- include('partials/admin-topbar', { activeAdminTab }) %>
  <%- include('partials/admin-toast') %>

  <section class="subpage-hero admin-page-hero">
    <div class="container subpage-copy">
      <p class="eyebrow">Tables</p>
      <h1>Track seat usage and release flow in real time.</h1>
      <p class="subpage-note">Each card shows seated duration, customer free ETA, and when the table is ready again.</p>
    </div>
  </section>

  <section class="container pb-5">
    <div class="admin-table-cards">
      <% tableCards.forEach((table) => { %>
        <article class="table-tile <%= table.status === 'AVAILABLE' ? 'is-ready' : 'is-busy' %> admin-table-card">
          <div class="d-flex justify-content-between align-items-start gap-2">
            <div>
              <span>Table <%= table.id %></span>
              <strong><%= table.capacity %> seats</strong>
            </div>
            <em><%= table.status %></em>
          </div>

          <div class="admin-table-meta">
            <p><small>Current guest</small><br><strong><%= table.customerName %></strong></p>
            <p><small>Phone</small><br><%= table.customerPhone %></p>
            <p><small>Seated since</small><br><span class="dynamic-since" data-time="<%= table.seatedSinceIso ? table.seatedSinceIso : '' %>"><%= table.seatedSinceLabel %></span></p>
            <p><small>Customer free in</small><br><span class="dynamic-wait" data-time="<%= table.customerFreeAt ? table.customerFreeAt.toISOString() : '' %>"><%= table.timeUntilCustomerFreeLabel %></span> (<%= table.customerFreeAtLabel %>)</p>
            <p><small>Table free in</small><br><span class="dynamic-wait" data-time="<%= table.tableFreeAt ? table.tableFreeAt.toISOString() : '' %>"><%= table.timeUntilTableFreeLabel %></span> (<%= table.tableFreeAtLabel %>)</p>
            <% if (table.resetInProgress) { %>
              <p><small>Reset buffer</small><br><span class="badge text-bg-secondary">In progress (~<%= resetBufferMinutes %> min policy)</span></p>
            <% } %>
          </div>

          <% if (table.resetInProgress) { %>
            <form action="/admin/tables/<%= table.id %>/reset-done" method="post" class="w-100 mt-3">
              <input type="hidden" name="returnTo" value="/admin/tables">
              <button class="btn btn-sm btn-gold w-100" type="submit">Reset done</button>
            </form>
          <% } else if (table.status === 'OCCUPIED' && table.activeBooking) { %>
            <div class="d-flex gap-2 mt-3">
              <form action="/admin/bookings/<%= table.activeBooking.id %>/extend" method="post" class="flex-grow-1">
                <input type="hidden" name="returnTo" value="/admin/tables">
                <button class="btn btn-sm btn-outline-light w-100" type="submit">+15m</button>
              </form>
              <form action="/admin/tables/<%= table.id %>/status" method="post" class="flex-grow-1">
                <input type="hidden" name="returnTo" value="/admin/tables">
                <input type="hidden" name="status" value="AVAILABLE">
                <button class="btn btn-sm btn-gold w-100" type="submit">Completed</button>
              </form>
            </div>
          <% } else { %>
            <form action="/admin/tables/<%= table.id %>/status" method="post" class="w-100 mt-3">
              <input type="hidden" name="returnTo" value="/admin/tables">
              <input type="hidden" name="status" value="OCCUPIED">
              <button class="btn btn-sm btn-outline-light w-100" type="submit">Mark Occupied</button>
            </form>
          <% } %>
        </article>
      <% }) %>
    </div>
  </section>

  <footer class="luxury-footer">
    <div class="container">
      <div class="footer-copy">Use this view during rush windows to manage release timing and faster table turns.</div>
      <div class="footer-copy">Aurevo Dining House</div>
    </div>
  </footer>
  <script>
    function formatMins(mins) {
      if (mins >= 60) {
        const h = Math.floor(mins / 60);
        const m = mins % 60;
        return m ? h + 'h ' + m + 'm' : h + 'h';
      }
      return mins + 'm';
    }

    function updateDynamicWaitTimes() {
      const now = new Date();
      document.querySelectorAll('.dynamic-wait').forEach(el => {
        const timeAttr = el.dataset.time;
        if (!timeAttr) return;
        const targetTime = new Date(timeAttr);
        const diffMs = now - targetTime;
        if (diffMs > 0) {
          const mins = Math.floor(diffMs / 60000);
          el.textContent = '0m (+' + formatMins(mins) + ')';
        } else {
          const remains = Math.ceil(-diffMs / 60000);
          el.textContent = formatMins(remains);
        }
      });

      document.querySelectorAll('.dynamic-since').forEach(el => {
        const timeAttr = el.dataset.time;
        if (!timeAttr) return;
        const targetTime = new Date(timeAttr);
        const diffMs = now - targetTime;
        if (diffMs >= 0) {
          const mins = Math.floor(diffMs / 60000);
          el.textContent = formatMins(mins);
        }
      });
    }
    setInterval(updateDynamicWaitTimes, 60000);
    updateDynamicWaitTimes();
  </script>
  <%- include('partials/sse-client') %>
</body>
</html>

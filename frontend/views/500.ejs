<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Aurevo Dining</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-shell">
  <section class="container py-5">
    <div class="empty-state">
      <p class="eyebrow">Service Interruption</p>
      <h1>Something went wrong</h1>
      <p>The app hit an unexpected issue. Please check the database connection and try again.</p>
      <% if (error) { %>
        <pre class="mt-3 text-start"><%= error.message %></pre>
      <% } %>
      <a class="btn btn-gold mt-4" href="/">Back to home</a>
    </div>
  </section>
</body>
</html>

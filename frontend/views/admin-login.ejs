<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Family Dining</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-shell">
  <%- include('partials/navbar', { activeTab: 'admin' }) %>
  <% if (flash) { %>
    <div class="container mt-3">
      <div class="alert alert-<%= flash.type %> shadow-sm"><%= flash.text %></div>
    </div>
  <% } %>
  <section class="subpage-hero">
    <div class="container subpage-copy">
      <p class="eyebrow">Secure Access</p>
      <h1>Admin control for floor and queue operations.</h1>
      <p class="subpage-note">A focused sign-in screen for the team managing bookings, table state, and premium guest flow.</p>
    </div>
  </section>
  <section class="container pb-5">
    <div class="status-shell two-column">
      <div class="reservation-panel compact mx-auto" style="max-width: 520px; width: 100%;">
        <div class="panel-header">
          <span class="panel-kicker">Admin Login</span>
          <h2>Enter the operations dashboard</h2>
          <p>Only authorized staff should access table controls and queue overrides.</p>
        </div>
        <form action="/admin/login" method="post" class="row g-3">
          <div class="col-12">
            <label class="form-label">Username</label>
            <input class="form-control luxury-input" type="text" name="username" required>
          </div>
          <div class="col-12">
            <label class="form-label">Password</label>
            <input class="form-control luxury-input" type="password" name="password" required>
          </div>
          <div class="col-12">
            <button class="btn btn-gold w-100" type="submit">Enter dashboard</button>
          </div>
        </form>
      </div>
      <aside class="support-card">
        <div class="panel-header">
          <span class="panel-kicker">Operations Focus</span>
          <h2>Inside the dashboard</h2>
        </div>
        <ul class="support-list">
          <li>Review confirmed and waiting guests in one place.</li>
          <li>Mark tables occupied or free to reflect the real floor.</li>
          <li>Promote priority guests when seating opens up.</li>
          <li>Keep the live menu accurate for the guest-facing site.</li>
        </ul>
      </aside>
    </div>
  </section>
  <footer class="luxury-footer">
    <div class="container">
      <div class="footer-copy">Secure operational access with a cleaner handoff into the restaurant control panel.</div>
      <div class="footer-copy">Family Dining House</div>
    </div>
  </footer>
</body>
</html>

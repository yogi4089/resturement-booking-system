<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Aurevo Dining</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-shell">
  <header class="topbar">
    <div class="container d-flex flex-wrap align-items-center justify-content-between gap-3 py-3">
      <a class="brand-mark text-decoration-none" href="/"><span class="brand-script">Aurevo</span><span class="brand-sub">Dining House</span></a>
      <nav class="nav nav-pills luxury-nav">
        <a class="nav-link" href="/">Booking</a>
        <a class="nav-link" href="/menu">Menu</a>
        <a class="nav-link" href="/status">Status</a>
        <a class="nav-link" href="/admin/login">Admin</a>
      </nav>
    </div>
  </header>
  <section class="subpage-hero">
    <div class="container subpage-copy">
      <p class="eyebrow">Curated Menu</p>
      <h1>Signature dishes with live availability.</h1>
      <p class="subpage-note">A polished public menu designed to reassure guests before they arrive and support queue-time recommendations.</p>
    </div>
  </section>
  <section class="container pb-5">
    <div class="menu-layout">
      <% menuItems.forEach((item) => { %>
        <article class="menu-card wide">
          <div>
            <h2><%= item.name %></h2>
            <p><%= item.availability ? "Ready to order now." : "Temporarily unavailable." %></p>
          </div>
          <div class="menu-side">
            <strong>Rs. <%= Number(item.price).toFixed(0) %></strong>
            <span class="badge text-bg-<%= item.availability ? "warning" : "secondary" %>"><%= item.availability ? "Available" : "Unavailable" %></span>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
  <footer class="luxury-footer">
    <div class="container">
      <div class="footer-copy">Live availability helps guests make better choices before and during waiting periods.</div>
      <div class="footer-copy">Aurevo Dining House</div>
    </div>
  </footer>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Aurevo Dining</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-shell">
  <header class="topbar">
    <div class="container d-flex flex-wrap align-items-center justify-content-between gap-3 py-3">
      <a class="brand-mark text-decoration-none" href="/"><span class="brand-script">Aurevo</span><span class="brand-sub">Dining House</span></a>
      <nav class="nav nav-pills luxury-nav">
        <a class="nav-link" href="/">Booking</a>
        <a class="nav-link" href="/menu">Menu</a>
        <a class="nav-link" href="/status">Status</a>
        <a class="nav-link" href="/admin">Dashboard</a>
      </nav>
    </div>
  </header>
  <% if (flash) { %>
    <div class="container mt-3">
      <div class="alert alert-<%= flash.type %> shadow-sm"><%= flash.text %></div>
    </div>
  <% } %>
  <section class="subpage-hero">
    <div class="container d-flex flex-wrap justify-content-between gap-3 align-items-end">
      <div class="subpage-copy">
        <p class="eyebrow">Operations Dashboard</p>
        <h1>Control bookings, queue flow, menu, and table readiness.</h1>
        <p class="subpage-note">A tighter command center for busy shifts, queue decisions, and real-world table updates.</p>
      </div>
      <form action="/admin/logout" method="post">
        <button class="btn btn-outline-light" type="submit">Logout</button>
      </form>
    </div>
  </section>
  <section class="container pb-5">
    <div class="metrics-grid mb-4">
      <article class="metric-card"><span>Confirmed</span><strong><%= data.analytics.confirmed_count %></strong></article>
      <article class="metric-card"><span>Waiting</span><strong><%= data.analytics.waiting_count %></strong></article>
      <article class="metric-card"><span>Average wait</span><strong><%= data.analytics.avg_wait_time %> mins</strong></article>
      <article class="metric-card"><span>Current profile</span><strong><%= data.analytics.current_wait_profile %> (x<%= data.analytics.current_profile_multiplier %>)</strong></article>
    </div>

    <div class="metrics-grid mb-4">
      <article class="metric-card"><span>MAE</span><strong><%= data.telemetry.mae %> mins</strong></article>
      <article class="metric-card"><span>MAPE</span><strong><%= data.telemetry.mape %>%</strong></article>
      <article class="metric-card"><span>No-show rate</span><strong><%= data.telemetry.no_show_rate %>%</strong></article>
      <article class="metric-card"><span>Promotion delay</span><strong><%= data.telemetry.promotion_delay %> mins</strong></article>
    </div>
    <section class="dashboard-panel mb-4">
      <div class="panel-header">
        <span class="panel-kicker">Demand Insights</span>
        <h2>Busy hours and popular days</h2>
        <p>Tracks when waiting times naturally rise so staff can plan proactively.</p>
      </div>
      <div class="demand-grid">
        <article class="support-card compact">
          <h3>Busiest Hours</h3>
          <% if (data.demandInsights.busyHours.length) { %>
            <ul class="support-list">
              <% data.demandInsights.busyHours.forEach((row) => { %>
                <li><strong><%= row.hour_slot %>:00</strong> - <%= row.total_bookings %> bookings (avg wait <%= row.avg_wait_time %> mins)</li>
              <% }) %>
            </ul>
          <% } else { %>
            <p>No booking trend data yet.</p>
          <% } %>
        </article>
        <article class="support-card compact">
          <h3>Popular Days</h3>
          <% if (data.demandInsights.popularDays.length) { %>
            <ul class="support-list">
              <% data.demandInsights.popularDays.forEach((row) => { %>
                <li><strong><%= row.day_name %></strong> - <%= row.total_bookings %> bookings (avg wait <%= row.avg_wait_time %> mins)</li>
              <% }) %>
            </ul>
          <% } else { %>
            <p>No weekday trend data yet.</p>
          <% } %>
        </article>
        <article class="support-card compact">
          <h3>Wait by Bucket</h3>
          <% if (data.demandInsights.waitByBucket.length) { %>
            <ul class="support-list">
              <% data.demandInsights.waitByBucket.forEach((row) => { %>
                <li><strong><%= row.demand_bucket %></strong> - <%= row.total_bookings %> bookings (avg wait <%= row.avg_wait_time %> mins)</li>
              <% }) %>
            </ul>
          <% } else { %>
            <p>No demand-bucket data yet.</p>
          <% } %>
        </article>
      </div>
    </section>

    <div class="dashboard-grid">
      <section class="dashboard-panel">
        <div class="panel-header">
          <span class="panel-kicker">Tables</span>
          <h2>Manual floor control</h2>
          <p>Reflect live room status with a single tap and immediately trigger queue movement when tables open.</p>
        </div>
        <div class="table-grid">
          <% data.tables.forEach((table) => { %>
            <div class="table-tile <%= table.status === 'AVAILABLE' ? 'is-ready' : 'is-busy' %>">
              <span>Table <%= table.id %></span>
              <strong><%= table.capacity %> seats</strong>
              <em><%= table.status %></em>
              <% if (table.reset_ready_at) { %>
                <small>Reset in progress until <%= new Date(table.reset_ready_at).toLocaleTimeString("en-IN", { hour: "numeric", minute: "2-digit" }) %></small>
                <form action="/admin/tables/<%= table.id %>/reset-done" method="post" class="w-100 mt-3">
                  <button class="btn btn-sm btn-gold w-100" type="submit">Reset done</button>
                </form>
              <% } else { %>
                <form action="/admin/tables/<%= table.id %>/status" method="post" class="w-100 mt-3">
                  <input type="hidden" name="status" value="<%= table.status === 'AVAILABLE' ? 'OCCUPIED' : 'AVAILABLE' %>">
                  <button class="btn btn-sm <%= table.status === 'AVAILABLE' ? 'btn-outline-light' : 'btn-gold' %> w-100" type="submit"><%= table.status === 'AVAILABLE' ? 'Mark Occupied' : 'Mark Free (start reset)' %></button>
                </form>
              <% } %>
            </div>
          <% }) %>
        </div>
      </section>

      <section class="dashboard-panel">
        <div class="panel-header">
          <span class="panel-kicker">Waiting Queue</span>
          <h2>Priority-first management</h2>
          <p>Guests appear in service order based on priority and arrival time, not simple FIFO.</p>
        </div>
        <div class="list-stack">
          <% if (data.queue.length) { %>
            <% data.queue.forEach((entry, index) => { %>
              <article class="list-card">
                <div>
                  <h3>#<%= index + 1 %> <%= entry.name %></h3>
                  <p><%= entry.guests %> guests &middot; <%= entry.priority_label %> &middot; <%= entry.phone %></p>
                </div>
                <form action="/admin/queue/<%= entry.booking_id %>/promote" method="post">
                  <button class="btn btn-gold btn-sm" type="submit">Override assign</button>
                </form>
              </article>
            <% }) %>
          <% } else { %>
            <div class="empty-state tight">
              <h3>No one is waiting</h3>
              <p>The queue is currently clear.</p>
            </div>
          <% } %>
        </div>
      </section>
    </div>

    <div class="dashboard-grid mt-4">
      <section class="dashboard-panel">
        <div class="panel-header">
          <span class="panel-kicker">Bookings</span>
          <h2>Recent reservations</h2>
          <p>Review guest details, service timing, table assignment, and confirmed records ready to close out.</p>
        </div>
        <div class="table-responsive">
          <table class="table table-dark align-middle">
            <thead>
              <tr>
                <th>ID</th>
                <th>Guest</th>
                <th>Schedule</th>
                <th>Status</th>
                <th>Table</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% data.bookings.forEach((booking) => { %>
                <tr>
                  <td><%= booking.id %></td>
                  <td><%= booking.name %><br><small><%= booking.phone %></small></td>
                  <td><%= booking.booking_date.toISOString().slice(0, 10) %> <%= booking.booking_time.toString().slice(0, 5) %></td>
                  <td><span class="badge text-bg-secondary"><%= booking.status %></span><br><small>Pred <%= booking.predicted_wait_minutes ?? 0 %>m / Act <%= booking.actual_wait_minutes ?? 0 %>m</small></td>
                  <td><%= booking.table_id || "-" %></td>
                  <td>
                    <div class="d-flex gap-2 flex-wrap">
                      <% if (booking.status === "CONFIRMED" && !booking.seated_at) { %>
                        <form action="/admin/bookings/<%= booking.id %>/seat" method="post">
                          <button class="btn btn-outline-light btn-sm" type="submit">Seat now</button>
                        </form>
                      <% } %>
                      <% if (booking.status === "CONFIRMED") { %>
                        <form action="/admin/bookings/<%= booking.id %>/extend" method="post">
                          <button class="btn btn-outline-light btn-sm" type="submit">Extend +15m</button>
                        </form>
                        <form action="/admin/bookings/<%= booking.id %>/complete" method="post">
                          <button class="btn btn-outline-light btn-sm" type="submit">Complete</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="dashboard-panel">
        <div class="panel-header">
          <span class="panel-kicker">Menu Admin</span>
          <h2>Update dishes and availability</h2>
          <p>Keep the public-facing menu current so guests always see what can be served immediately.</p>
        </div>
        <form action="/admin/menu" method="post" class="row g-3 mb-4">
          <div class="col-md-7"><input class="form-control luxury-input" type="text" name="name" placeholder="Dish name" required></div>
          <div class="col-md-3"><input class="form-control luxury-input" type="number" step="0.01" min="0" name="price" placeholder="Price" required></div>
          <div class="col-md-2"><button class="btn btn-gold w-100" type="submit">Add</button></div>
        </form>
        <div class="list-stack">
          <% data.menuItems.forEach((item) => { %>
            <article class="list-card">
              <div>
                <h3><%= item.name %></h3>
                <p>Rs. <%= Number(item.price).toFixed(0) %> &middot; <%= item.availability ? "Available" : "Unavailable" %></p>
              </div>
              <div class="d-flex gap-2 flex-wrap">
                <form action="/admin/menu/<%= item.id %>/toggle" method="post">
                  <button class="btn btn-outline-light btn-sm" type="submit">Toggle</button>
                </form>
                <form action="/admin/menu/<%= item.id %>/delete" method="post" onsubmit="return confirm('Delete this menu item permanently?');">
                  <button class="btn btn-outline-light btn-sm" type="submit">Delete</button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    </div>
  </section>
  <footer class="luxury-footer">
    <div class="container">
      <div class="footer-copy">A cleaner operations surface helps staff make faster seating, queue, and service decisions.</div>
      <div class="footer-copy">Aurevo Dining House</div>
    </div>
  </footer>
</body>
</html>


